{
  "name": "products-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --testPathPattern=tests/unit",
    "test:int": "jest --runInBand --testPathPattern=tests/integration",
    "test:coverage": "jest --runInBand --coverage",
    "migrate": "npx prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "winston": "^3.19.0",
    "zod": "^4.3.6",
    "ts-jest": "^29.4.9"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@types/supertest": "^7.2.0",
    
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
